@model WebsiteBanHang.Models.Order

@{
    ViewData["Title"] = "Thanh toán";
}

<section class="container page-section">
    <div class="checkout-card">
        <span class="eyebrow">Checkout</span>
        <h2>Thông tin giao hàng</h2>

        <form asp-action="Checkout" method="post" class="mt-4">
            <div class="mb-3">
                <label asp-for="ShippingAddress" class="form-label">Địa chỉ giao hàng</label>
                <input asp-for="ShippingAddress" class="form-control" placeholder="Nhập số nhà, đường, phường/xã, quận/huyện..." />
                <span asp-validation-for="ShippingAddress" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label">Ghi chú</label>
                <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Thời gian nhận hàng, lưu ý khi giao..."></textarea>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-dark">
                    <i class="bi bi-check2-circle"></i> Đặt hàng
                </button>
                <a asp-action="Index" class="btn btn-outline-dark">Quay lại giỏ hàng</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
