@model WebsiteBanHang.Models.ShoppingCart

@{
    ViewData["Title"] = "Giỏ hàng";
}

<section class="container page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Shopping cart</span>
            <h2>Giỏ hàng của bạn</h2>
        </div>
        <a class="btn btn-outline-dark" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left"></i> Tiếp tục mua hàng
        </a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <i class="bi bi-cart-x"></i>
            <h3>Giỏ hàng đang trống</h3>
            <p>Hãy chọn sản phẩm yêu thích rồi quay lại đây để thanh toán.</p>
            <a class="btn btn-dark" asp-controller="Home" asp-action="Index">Xem sản phẩm</a>
        </div>
    }
    else
    {
        <div class="cart-layout">
            <div class="table-responsive cart-table">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Giá</th>
                            <th class="text-end">Tổng</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="cart-product">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" />
                                        }
                                        else
                                        {
                                            <span class="cart-thumb-placeholder"><i class="bi bi-image"></i></span>
                                        }
                                        <span>@item.Name</span>
                                    </div>
                                </td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.Price.ToString("#,##0") VNĐ</td>
                                <td class="text-end fw-bold">@((item.Price * item.Quantity).ToString("#,##0")) VNĐ</td>
                                <td class="text-end">
                                    <form asp-action="RemoveFromCart" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button class="btn btn-outline-danger btn-sm" type="submit">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <aside class="order-summary">
                <h3>Tóm tắt đơn hàng</h3>
                <div class="summary-row">
                    <span>Số lượng</span>
                    <strong>@Model.TotalQuantity</strong>
                </div>
                <div class="summary-row total">
                    <span>Thành tiền</span>
                    <strong>@Model.TotalPrice.ToString("#,##0") VNĐ</strong>
                </div>
                <a class="btn btn-dark w-100" asp-action="Checkout">
                    <i class="bi bi-credit-card"></i> Tới trang thanh toán
                </a>
            </aside>
        </div>
    }
</section>
