@model IEnumerable<WebsiteBanHang.Models.Category>

@{
    ViewData["Title"] = "Quản lý danh mục";
}

<section class="container page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Admin</span>
            <h2>Quản lý danh mục</h2>
        </div>
        <a asp-action="Add" class="btn btn-dark">
            <i class="bi bi-plus-circle"></i> Thêm danh mục
        </a>
    </div>

    <div class="table-responsive cart-table">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Tên danh mục</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>@cat.Id</td>
                        <td class="fw-bold">@cat.Name</td>
                        <td class="text-end">
                            <a asp-action="Display" asp-route-id="@cat.Id" class="btn btn-outline-dark btn-sm">Xem</a>
                            <a asp-action="Update" asp-route-id="@cat.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@cat.Id" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
