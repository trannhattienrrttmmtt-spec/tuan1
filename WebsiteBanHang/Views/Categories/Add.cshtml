@model WebsiteBanHang.Models.Category

@{
    ViewData["Title"] = "Thêm danh mục";
}

<section class="container page-section">
    <div class="checkout-card">
        <span class="eyebrow">Category</span>
        <h2>Thêm danh mục mới</h2>

        <form asp-action="Add" method="post" class="mt-4">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Tên danh mục</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-dark">Thêm</button>
            <a asp-action="Index" class="btn btn-outline-dark">Quay lại</a>
        </form>
    </div>
</section>
