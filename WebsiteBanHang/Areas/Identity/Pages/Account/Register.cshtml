@page
@model WebsiteBanHang.Areas.Identity.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Đăng ký";
}

<section class="auth-shell auth-shell-register">
    <div class="auth-visual">
        <div>
            <span class="eyebrow">TIEN STORE</span>
            <h1>Tạo tài khoản mua hàng</h1>
            <p>Hoàn tất thông tin để bắt đầu thêm sản phẩm vào giỏ và đặt hàng nhanh hơn.</p>
        </div>
    </div>

    <div class="auth-panel">
        <div class="auth-card">
            <span class="eyebrow">New account</span>
            <h2>Đăng ký</h2>
            <p class="auth-muted">Thông tin được dùng cho việc giao hàng và quản lý đơn.</p>

            <form id="registerForm" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="form-floating">
                    <input asp-for="Input.FullName" class="form-control" autocomplete="name" placeholder="Họ và tên" />
                    <label asp-for="Input.FullName">Họ và tên</label>
                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.Address" class="form-control" autocomplete="street-address" placeholder="Địa chỉ" />
                    <label asp-for="Input.Address">Địa chỉ</label>
                    <span asp-validation-for="Input.Address" class="text-danger small"></span>
                </div>

                <div class="auth-grid-2">
                    <div class="form-floating">
                        <input asp-for="Input.Age" class="form-control" placeholder="Tuổi" />
                        <label asp-for="Input.Age">Tuổi</label>
                    </div>

                    <div class="form-floating">
                        <select asp-for="Input.Role" asp-items="Model.RoleList" class="form-select">
                            <option value="">Customer</option>
                        </select>
                        <label asp-for="Input.Role">Vai trò</label>
                    </div>
                </div>

                <div class="auth-grid-2">
                    <div class="form-floating">
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" placeholder="Mật khẩu" />
                        <label asp-for="Input.Password">Mật khẩu</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating">
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu" />
                        <label asp-for="Input.ConfirmPassword">Nhập lại mật khẩu</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-dark w-100 btn-lg">
                    <i class="bi bi-person-plus"></i> Tạo tài khoản
                </button>
            </form>

            <div class="auth-switch">
                Đã có tài khoản?
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Đăng nhập</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
