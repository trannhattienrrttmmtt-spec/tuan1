@page
@model WebsiteBanHang.Areas.Identity.Pages.Account.Manage.ChangePasswordModel

@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<section class="container page-section">
    <div class="profile-layout">
        <aside class="profile-sidebar">
            <i class="bi bi-key"></i>
            <h2>Bảo mật tài khoản</h2>
            <p>Đổi mật khẩu định kỳ để giữ tài khoản an toàn.</p>

            <div class="profile-actions">
                <a class="btn btn-outline-dark w-100" asp-page="./Index">
                    <i class="bi bi-person-lines-fill"></i> Hồ sơ
                </a>
                <a class="btn btn-dark w-100" asp-page="./ChangePassword">
                    <i class="bi bi-key"></i> Đổi mật khẩu
                </a>
            </div>
        </aside>

        <div class="profile-card">
            <span class="eyebrow">Security</span>
            <h2>Đổi mật khẩu</h2>
            <p class="text-muted">Mật khẩu mới nên có chữ hoa, chữ thường, số hoặc ký tự đặc biệt.</p>

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert alert-success mt-3">@Model.StatusMessage</div>
            }

            <form method="post" class="auth-form mt-4">
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <div class="form-floating">
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" placeholder="Mật khẩu hiện tại" />
                    <label asp-for="Input.OldPassword">Mật khẩu hiện tại</label>
                    <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="Mật khẩu mới" />
                    <label asp-for="Input.NewPassword">Mật khẩu mới</label>
                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Nhập lại mật khẩu mới" />
                    <label asp-for="Input.ConfirmPassword">Nhập lại mật khẩu mới</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-dark">
                    <i class="bi bi-shield-check"></i> Cập nhật mật khẩu
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
