@model WebsiteBanHang.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Admin - Cập nhật sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>Cập nhật sản phẩm (Admin)</h2>
    <hr />

    <form asp-area="Admin" asp-controller="Product" asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="Name">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Price">Giá</label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Description">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CategoryId">Danh mục</label>
                    <select asp-for="CategoryId" asp-items="@ViewBag.Categories" class="form-control">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                </div>
                <div class="form-group mb-3">
                    <label>Hình ảnh mới (để trống nếu không thay đổi)</label>
                    <input type="file" asp-for="ImageUrl" class="form-control" id="imgInput" accept="image/*" />
                </div>
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
            </div>
            <div class="col-md-4">
                <label>Hình ảnh hiện tại</label><br />
                <img id="preview" src="@Model.ImageUrl" style="max-width:250px;" class="rounded shadow" />
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('imgInput').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = ev => document.getElementById('preview').src = ev.target.result;
                reader.readAsDataURL(file);
            }
        });
    </script>
}
