@model IEnumerable<WebsiteBanHang.Models.Product>

@{
    ViewData["Title"] = "Admin - Quản lý sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="container page-section">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Admin</span>
            <h2>Quản lý sản phẩm</h2>
        </div>
        <a asp-area="Admin" asp-controller="Product" asp-action="Add" class="btn btn-dark">
            <i class="bi bi-plus-circle"></i> Thêm sản phẩm
        </a>
    </div>

    <div class="table-responsive cart-table">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá</th>
                    <th>Danh mục</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" style="width:72px;height:58px;object-fit:cover;border-radius:8px;" alt="@product.Name" />
                            }
                        </td>
                        <td class="fw-bold">@product.Name</td>
                        <td>@product.Price.ToString("#,##0") VNĐ</td>
                        <td>@product.Category?.Name</td>
                        <td class="text-end">
                            <a asp-area="Admin" asp-controller="Product" asp-action="Update" asp-route-id="@product.Id" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
